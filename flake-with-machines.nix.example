# This is an EXAMPLE of how flake.nix would be modified to support machine-specific configs
# DO NOT rename this to flake.nix - it's just a reference implementation
#
# Key changes from current flake.nix:
# 1. mkDarwinSystem accepts optional machineConfig parameter
# 2. Machine configs can override packages and module settings
# 3. Cleaner separation between core config and machine-specific overrides

{
  description = "Development packages for Mike Flood";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
    flake-parts.url = "github:hercules-ci/flake-parts";

    home-manager = {
      url = "github:nix-community/home-manager/master";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    darwin = {
      url = "github:lnl7/nix-darwin";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    neovim-nightly-overlay.url = "github:nix-community/neovim-nightly-overlay";
    zig.url = "github:mitchellh/zig-overlay";
    ghostty.url = "github:ghostty-org/ghostty";

    fenix = {
      url = "github:nix-community/fenix/monthly";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs =
    inputs@{ flake-parts, ... }:
    flake-parts.lib.mkFlake { inherit inputs; } {
      systems = [ "aarch64-darwin" ];
      perSystem = {
        system,
        pkgs,
        ...
      }: { };

      flake = {
        # ENHANCED: Helper function now accepts optional machine config
        lib.mkDarwinSystem =
          {
            username,
            system ? "aarch64-darwin",
            machineConfig ? null, # NEW: Optional machine-specific config
          }:
          let
            darwin = inputs.darwin;

            pkgs-config = {
              allowUnfree = true;
              allowUnsupportedSystem = true;
              permittedInsecurePackages = [
                "dotnet-core-combined"
                "dotnet-sdk-6.0.428"
                "dotnet-sdk-wrapped-6.0.428"
                "dotnet-runtime-6.0.36"
                "dotnet-runtime-wrapped-6.0.36"
              ];
            };

            lib = import ./lib { inherit pkgs inputs; };
            overlays = import ./lib/overlays.nix (
              { inherit inputs system username; } // (if lib != null then { inherit lib; } else { })
            );
            pkgs = import inputs.nixpkgs {
              inherit system overlays;
              config = pkgs-config;
            };

            # NEW: Load machine-specific config if provided
            machineSettings =
              if machineConfig != null then
                import machineConfig {
                  inherit pkgs username;
                }
              else
                {
                  machine = { };
                  extraSystemPackages = [ ];
                  extraHomePackages = [ ];
                  modules = { };
                  environment = { };
                };
          in
          pkgs.mkDarwin {
            inherit
              darwin
              system
              pkgs
              username
              ;
            # NEW: Pass machine settings to the builder
            inherit (machineSettings)
              extraSystemPackages
              extraHomePackages
              machine
              environment
              ;
          };

        # ENHANCED: darwinConfigurations now supports machine-specific configs
        darwinConfigurations =
          let
            mkDarwinSystem = inputs.self.lib.mkDarwinSystem;
          in
          {
            # Machine-specific configurations
            "mikes-macbook" = mkDarwinSystem {
              username = "mike";
              machineConfig = ./machines/personal-macbook.nix;
            };

            "work-laptop" = mkDarwinSystem {
              username = "chmc-h022fl97xj";
              machineConfig = ./machines/work-macbook.nix;
            };

            # Generic username-based configs (backwards compatible)
            mike = mkDarwinSystem { username = "mike"; };
            chmc-h022fl97xj = mkDarwinSystem { username = "chmc-h022fl97xj"; };

            # Convenience aliases
            default = mkDarwinSystem {
              username = "mike";
              machineConfig = ./machines/personal-macbook.nix;
            };
            work = mkDarwinSystem {
              username = "chmc-h022fl97xj";
              machineConfig = ./machines/work-macbook.nix;
            };
          };
      };
    };
}
